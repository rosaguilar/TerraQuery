# Vertex AI + Earth Engine Credentials
# ------------------------------------

# JSON payload for your GCP service account (needs EE and Vertex AI permissions)
# Example: '{"type": "service_account", "project_id": "your-project", ...}'
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Google Cloud Project ID where the Vertex AI model is deployed
GCP_PROJECT_ID=

# The specific endpoint ID for your deployed Vertex AI model
# Format typically looks like: 1234567890123456789
VERTEX_ENDPOINT_ID=

# Region where your endpoint is deployed (europe-west4 is highly recommended for Earth Engine)
VERTEX_REGION=europe-west4

# Server port (default 3001)
PORT=3001
